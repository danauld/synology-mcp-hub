# Gramps MCP env vars (mcp-grampsweb, Node).
#
# Copy this to /volume1/docker/synology-mcp-hub/env/gramps.env on the
# Synology host. The Hub container joins `grampsweb_default` network, so
# `grampsweb` is resolvable via Docker DNS on its private port 5000.

GRAMPS_API_URL=http://grampsweb:5000
GRAMPS_USERNAME=
GRAMPS_PASSWORD=
