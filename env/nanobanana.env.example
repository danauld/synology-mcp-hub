# env/nanobanana.env — env vars for the nanobanana MCP program in supervisord.
#
# Copy this file to /volume1/docker/synology-mcp-hub/env/nanobanana.env on the
# Synology host and fill in the GEMINI_API_KEY value.
#
# The other nanobanana env vars (FASTMCP_TRANSPORT/HOST/PORT, IMAGE_OUTPUT_DIR)
# are baked into supervisord.conf as the program-level `environment=...` line —
# only the secret needs to live here.
#
# GEMINI_API_KEY: Google AI Studio API key with access to Gemini image
# generation models (Flash 3.1 / Pro 3 / 2.5 Flash). Generated at
# https://aistudio.google.com/app/apikey. Currently the same value as the
# `GEMINI_API_KEY` GCP Secret Manager secret used by the Cloud Run deployment
# (which can be retired once this Hub deployment is verified).

GEMINI_API_KEY=
