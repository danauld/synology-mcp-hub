# env/whatsupp.env — env vars for the whatsupp MCP program in supervisord.
#
# Copy this file to /volume1/docker/synology-mcp-hub/env/whatsupp.env on the
# Synology host and fill in the values.
#
# The other whatsupp env vars (PORT, TRANSPORT, MCP_ENDPOINT, NODE_ENV) are
# baked into supervisord.conf as the program-level `environment=...` line —
# only the secrets need to live here.
#
# SUPABASE_URL: HTTPS URL of the Supabase project hosting the meds tables.
# Currently the "Medical and Wellness" project (rafybjboggundidsdwjz) in
# region ap-northeast-1.
#
# SUPABASE_SERVICE_ROLE_KEY: Supabase service_role JWT (NOT the anon key).
# Required because every public health table has RLS enabled with policies
# scoped to roles={authenticated} and gated on a row in public.patient_access
# for the requester's auth.uid(); patient_access is empty, so anon/authenticated
# requests return zero rows. service_role bypasses RLS — same key the HA
# Balmoral REST edge command (NFC tag pathway) uses to write log rows.
# Generate / reveal at:
#   Supabase Dashboard → Project Settings → API → "Project API keys"
#   → "service_role" → reveal the secret value.
# This key has full admin access to the project — keep it in env files,
# never commit, never expose to a browser/client.

SUPABASE_URL=https://rafybjboggundidsdwjz.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
