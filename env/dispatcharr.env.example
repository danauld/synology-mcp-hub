# Dispatcharr MCP env vars.
#
# Copy this to /volume1/docker/synology-mcp-hub/env/dispatcharr.env on the
# Synology host. The Hub container joins `dispatcharr_default` network, so
# `dispatcharr` is resolvable via Docker DNS.

DISPATCHARR_URL=http://dispatcharr:9191
DISPATCHARR_API_KEY=

# Optional tuning for stream-probe parallelism.
STREAM_PROBE_CONCURRENCY=8
STREAM_PROBE_TIMEOUT_S=6
