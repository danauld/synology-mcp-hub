# ARR MCP env vars (Sonarr / Radarr / Prowlarr).
#
# Copy this to /volume1/docker/synology-mcp-hub/env/arr.env on the Synology host.
# Values are read by mcp-arr at process startup. The container reaches the
# arr backends by Docker network DNS via the joined sonarr_default network.

# Sonarr
SONARR_URL=http://sonarr:8989
SONARR_API_KEY=

# Radarr
RADARR_URL=http://radarr:7878
RADARR_API_KEY=

# Prowlarr
PROWLARR_URL=http://prowlarr:9696
PROWLARR_API_KEY=
