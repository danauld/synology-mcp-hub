# ARR MCP env vars (Sonarr / Radarr / Prowlarr).
#
# Copy this to /volume1/docker/synology-mcp-hub/env/arr.env on the Synology host.
# mcp-arr expects HOST + PORT (NOT URL). All three backends are reachable via
# the Synology host IP on their published ports — no Docker network DNS needed.

SONARR_HOST=192.168.4.79
SONARR_PORT=8989
SONARR_API_KEY=

RADARR_HOST=192.168.4.79
RADARR_PORT=7878
RADARR_API_KEY=

PROWLARR_HOST=192.168.4.79
PROWLARR_PORT=9696
PROWLARR_API_KEY=

LOG_LEVEL=INFO
