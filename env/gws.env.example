# gws-mcp env (Google Workspace MCP — Drive / Tasks / Gmail / Contacts)
#
# GWS_CREDENTIALS is the unencrypted output of `gws auth export --unmasked`,
# captured locally with `gws auth login` (or the explicit-scope Python OAuth
# fallback for v0.7.0's broken --scopes flag — see Obsidian Google Workspace
# MCP.md "Refreshing credentials" section).
#
# JSON shape:
#   {"client_id":"...","client_secret":"...","refresh_token":"...","type":"authorized_user"}
#
# Single-line, no whitespace inside the value, single-quoted to survive any
# special chars in the JSON. The Hub's mcps/gws/start.sh wrapper hydrates the
# four ~/.config/gws/ files from this at supervisord program start.
#
# To rotate (e.g. after revocation):
#   1. Local: re-run /tmp/gws-oauth.py with the desired scope list
#   2. cat ~/.config/gws/credentials.json
#   3. Replace the GWS_CREDENTIALS= line below with the new JSON on one line
#   4. Restart the mcp-hub container (supervisord program restart isn't enough
#      because env_file is consumed at container create time)

GWS_CREDENTIALS='{"client_id":"REPLACE","client_secret":"REPLACE","refresh_token":"REPLACE","type":"authorized_user"}'
