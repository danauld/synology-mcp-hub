# Trakt MCP env vars.
#
# Copy this to /volume1/docker/synology-mcp-hub/env/trakt.env on the
# Synology host, then `docker restart mcp-hub`.
#
# Get TRAKT_CLIENT_ID + TRAKT_CLIENT_SECRET from the Trakt API app dashboard:
#   https://trakt.tv/oauth/applications
# (originally migrated 2026-04-25 from GCP Secret Manager — secrets
# `TRAKT_CLIENT_ID` and `TRAKT_CLIENT_SECRET` in project
# `gen-lang-client-0819568261`).

TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=

# Persistent OAuth token path inside the container. The supervisord
# program block sets this — only override here if you change the bind
# mount in docker-compose.yml.
# TRAKT_AUTH_TOKEN_PATH=/state/trakt/auth_token.json
